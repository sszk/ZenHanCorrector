{
  "manifest_version": 3,
  "name": "ZenHan Corrector",
  "version": "0.1.0",
  "description": "全角英数字を半角に、半角カナを全角カタカナに変換してページ上に表示します。",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ZenHan Corrector"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "commands": {
    "toggle-enabled": {
      "suggested_key": {
        "default": "Alt+Shift+Z",
        "mac": "Alt+Shift+Z"
      },
      "description": "変換の有効/無効を切り替える"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/converter.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
